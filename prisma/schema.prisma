generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  engineType   = "client"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model User {
  id         Int          @id @default(autoincrement())
  email      String       @unique(map: "User_email_key")
  userName   String
  password   String
  role       Role         @default(USER)
  isActive   Boolean?     @default(true)
  isVerified Boolean      @default(false)
  ownedTasks Task[]       @relation("CreatedTasks")
  tasks      Task[]       @relation("AssignedTasks")
  teams      TeamMember[]
  projects   Project[]    @relation("ProjectOwner") 
  updatedAt  DateTime     @updatedAt
  createdAt  DateTime     @default(now())
}

model Task {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  status      Status    @default(PENDING)
  priority    Priority  @default(MEDIUM)
  dueDate     DateTime?
  createdBy   User      @relation("CreatedTasks", fields: [createdById], references: [id])
  createdById Int
  assignedTo  User?     @relation("AssignedTasks", fields: [assignedId], references: [id])
  assignedId  Int?
  project     Project?  @relation(fields: [projectId], references: [id],onDelete: SetNull)
  projectId   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Project {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  status      Status    @default(PENDING)
  owner       User      @relation("ProjectOwner", fields: [ownerId], references: [id]) // 👈 matched name
  ownerId     Int
  tasks       Task[]
  team        Team?     @relation(fields: [teamId], references: [id])
  teamId      Int?
  startDate   String    
  endDate     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Team {
  id        Int          @id @default(autoincrement())
  name      String
  createdAt DateTime     @default(now())
  members   TeamMember[]
  projects  Project[]
}

model TeamMember {
  id     Int      @id @default(autoincrement())
  user   User     @relation(fields: [userId], references: [id])
  userId Int
  team   Team     @relation(fields: [teamId], references: [id])
  teamId Int
  role   TeamRole @default(MEMBER)
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum Status {
  PENDING
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}